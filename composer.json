{
  "name": "ez-php/bignum",
  "version": "1.6.1",
  "description": "Arbitrary-precision integer and decimal arithmetic for the ez-php ecosystem — immutable BigInteger and BigDecimal value objects backed by bcmath (gmp optional)",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["bignum", "biginteger", "bigdecimal", "arbitrary-precision", "bcmath", "gmp", "math", "php", "ez-php"],
  "homepage": "https://github.com/ez-php/bignum",
  "support": {
    "issues": "https://github.com/ez-php/bignum/issues",
    "source": "https://github.com/ez-php/bignum"
  },
  "require": {
    "php": "^8.5",
    "ext-gmp": "*"
  },
  "suggest": {
    "ext-bcmath": "Alternative integer arithmetic backend (BcMathBackend)"
  },
  "require-dev": {
    "ez-php/docker": "^1.0",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\BigNum\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
